{
  "name": "@totvibe/stickynotes",
  "version": "0.0.0",
  "private": true,
  "description": "KDE Plasma 6 sticky notes — files-as-source-of-truth",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:cli": "bun build --compile --minify src/cli/main.ts --outfile dist/sticky",
    "spdx": "bun run scripts/check-spdx.ts",
    "qml:lint": "bash scripts/qml-lint.sh",
    "qml:format": "bash scripts/qml-format.sh --check",
    "qml:format:fix": "bash scripts/qml-format.sh --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "fast-check": "^4.7.0",
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "dependencies": {
    "cac": "^7.0.0"
  }
}
